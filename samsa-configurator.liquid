<div class="page-width" style="margin-top:60px; margin-bottom:60px;">

  <h3 class="configurator-title">
    {{ section.settings.title }}
  </h3>

  <div class="configurator-wrapper">
    <iframe
      id="samsa-iframe"
      src="{{ section.settings.iframe_url }}"
      allow="fullscreen; xr-spatial-tracking"
      allowfullscreen
    ></iframe>
  </div>

  <button
    id="add-configured"
    class="button button--primary configurator-button"
  >
    {{ section.settings.button_text }}
  </button>

</div>

<script>
var _samsaConfig = { keys: {}, readable: {} };
var _samsaOrigin = {{ section.settings.iframe_url | split: '/' | slice: 0, 3 | join: '/' | json }};

window.addEventListener("message", function(event) {
  if (event.origin !== _samsaOrigin) return;
  if (!event.data || event.data.type !== "CONFIG_UPDATE") return;
  _samsaConfig.keys     = event.data.payload  || {};
  _samsaConfig.readable = event.data.readable || {};
});

document.getElementById("add-configured").addEventListener("click", function() {
  var btn = this;
  btn.disabled = true;
  btn.textContent = "Adding...";

  if (!_samsaConfig.readable.body) {
    alert("Please customize your suitcase first!");
    btn.disabled = false;
    btn.textContent = {{ section.settings.button_text | json }};
    return;
  }

  var variants = {{ product.variants | json }};
  var bodyColor = (_samsaConfig.readable.body || "Aluminium").toLowerCase();

  var selectedVariant = null;
  for (var i = 0; i < variants.length; i++) {
    var opt = (variants[i].option1 || "").toLowerCase();
    if (opt.includes(bodyColor) || bodyColor.includes(opt)) {
      selectedVariant = variants[i];
      break;
    }
  }
  var variantId = selectedVariant ? selectedVariant.id : variants[0].id;

  fetch("/cart/add.js", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      id: variantId,
      quantity: 1,
      properties: {
        "Body Color":    _samsaConfig.readable.body    || "Not selected",
        "Handles Color": _samsaConfig.readable.handles || "Not selected",
        "Corners Color": _samsaConfig.readable.corners || "Not selected",
        "Wheels Color":  _samsaConfig.readable.wheels  || "Not selected",
        "_Customized": "Yes"
      }
    })
  })
  .then(function(res) {
    if (!res.ok) throw new Error("Cart error");
    return res.json();
  })
  .then(function() {
    window.location.href = "/cart";
  })
  .catch(function() {
    alert("Error adding to cart. Please try again.");
    btn.disabled = false;
    btn.textContent = {{ section.settings.button_text | json }};
  });
});
</script>

<style>
.configurator-title {
  text-align: center;
  margin-bottom: 25px;
  font-weight: 500;
  letter-spacing: 1px;
  font-size: 18px;
  text-transform: uppercase;
  opacity: 0.8;
}

.configurator-wrapper {
  width: 100%;
  height: 75vh;
  max-height: 900px;
  min-height: 500px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 30px 80px rgba(0,0,0,0.12);
  background: #000;
  position: relative;
}

.configurator-wrapper iframe {
  width: 100%;
  height: 100%;
  border: none;
  display: block;
}

.configurator-button {
  margin-top: 35px;
  width: 100%;
  max-width: 600px;
  display: block;
  margin-left: auto;
  margin-right: auto;
  font-weight: 600;
  letter-spacing: 0.5px;
  transition: all 0.3s ease;
}

.configurator-button:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

@media (max-width: 768px) {
  .configurator-wrapper {
    height: 60vh;
    min-height: 400px;
    border-radius: 16px;
  }
  .configurator-title {
    font-size: 16px;
    margin-bottom: 20px;
  }
  .configurator-button {
    max-width: 100%;
  }
}

@media (max-width: 480px) {
  .configurator-wrapper {
    height: 55vh;
    min-height: 350px;
  }
}

.product-form__submit,
button[type="submit"][name="add"],
.shopify-payment-button {
  display: none !important;
}
</style>

{% schema %}
{
  "name": "Samsa 3D Configurator",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "iframe_url",
      "label": "Configurator URL",
      "default": "https://maleta-3d-test.vercel.app/",
      "info": "URL del configurador desplegado"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customize your suitcase"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Add configured suitcase"
    }
  ],
  "presets": [
    {
      "name": "Samsa 3D Configurator"
    }
  ]
}
{% endschema %}
